#@ Placement
PLACEMENT_CONSTRAINT=node.hostname==<hostname>
#@ Container Config
#-  - SENTRY_RELAY_DATA_PATH -
#     Persistent storage path for generated Relay config and credentials.
SENTRY_RELAY_DATA_PATH=/mnt/user/appdata/sentry-relay
#@ Relay Config
#-  - RELAY_IMAGE -
RELAY_IMAGE=ghcr.io/getsentry/relay:26.6.0
#-  - RELAY_UPSTREAM_URL -
#     Internal Sentry web URL reachable from this Relay.
RELAY_UPSTREAM_URL=http://10.0.0.50:9000/
#-  - RELAY_ID -
#     Relay credentials identity UUID.
RELAY_ID=00000000-0000-0000-0000-000000000000
#-  - RELAY_PUBLIC_KEY -
RELAY_PUBLIC_KEY=
#-  - RELAY_SECRET_KEY -
RELAY_SECRET_KEY=
#-  - RELAY_LOG_LEVEL -
RELAY_LOG_LEVEL=WARN
#-  - RELAY_STATSD_ADDR -
RELAY_STATSD_ADDR=
#-  - RELAY_PUBLISHED_PORT -
RELAY_PUBLISHED_PORT=3000
#-  - RELAY_MAX_MEMORY_PERCENT -
#     Optional workaround for Relay healthcheck issues on some hosts.
RELAY_MAX_MEMORY_PERCENT=0.95
#-  - RELAY_SPOOL_MAX_BACKPRESSURE_MEMORY_PERCENT -
RELAY_SPOOL_MAX_BACKPRESSURE_MEMORY_PERCENT=0.95
